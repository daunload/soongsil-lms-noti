# 숭실대학교 LMS 로그인 정보
SSU_ID=학번
SSU_PW=비밀번호

# 이메일 발신 설정 (SMTP)
# MAILSERVICE, HOSTMAIL, MAILPORT 는 기본값(gmail / smtp.gmail.com / 587)이 적용됩니다.
AUTHUSER=your-email@gmail.com
AUTHPASS=your-app-password

# 알림을 받을 이메일 주소
NOTIFY_EMAIL=your-notify-email@example.com

# 로컬 개발 시 브라우저 헤드리스 모드 끄기 (선택)
# PLAYWRIGHT_HEADLESS=false
